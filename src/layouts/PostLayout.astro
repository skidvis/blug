---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.vue';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  tags?: string[];
  coverImage?: string;
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  tags = [],
  coverImage,
} = Astro.props;

// Long-form date for the header; short form for the updated line
const formatDateLong = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const formatDateShort = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title={title} description={description}>

  <!--
    Post layout: single centred column up to max-w-[46rem] for the prose,
    inside a max-w-4xl container so header/footer breathe wider.
  -->
  <div class="mx-auto max-w-4xl">
    <article itemscope itemtype="https://schema.org/BlogPosting">

      <!-- ═══════════════ POST HEADER ════════════════════════════ -->
      <header class="mb-12 space-y-8">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb">
          <a href="/" class="breadcrumb-link">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            All posts
          </a>
        </nav>

        <!-- Title block -->
        <div class="space-y-4">
          <span class="eyebrow">Article</span>

          <h1
            class="text-balance text-3xl font-extrabold tracking-tight text-base-content sm:text-4xl lg:text-[2.75rem] lg:leading-[1.15]"
            itemprop="headline"
          >
            {title}
          </h1>

          <p class="max-w-prose text-lg leading-relaxed text-base-content/60" itemprop="description">
            {description}
          </p>
        </div>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-base-content/45">
          <!-- Publish date -->
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8"  y1="2" x2="8"  y2="6"/>
              <line x1="3"  y1="10" x2="21" y2="10"/>
            </svg>
            <time datetime={publishDate.toISOString()} itemprop="datePublished">
              {formatDateLong(publishDate)}
            </time>
          </span>

          {updatedDate && (
            <span class="inline-flex items-center gap-1.5 text-base-content/35">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="23 4 23 10 17 10"/>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
              </svg>
              <time datetime={updatedDate.toISOString()} itemprop="dateModified">
                Updated {formatDateShort(updatedDate)}
              </time>
            </span>
          )}
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <TagList
            client:load
            tags={tags}
            ariaLabel="Post tags"
          />
        )}

        <!-- Cover image -->
        {coverImage && (
          <figure class="overflow-hidden rounded-2xl border border-base-300/70 bg-base-200 shadow-sm">
            <img
              src={coverImage}
              alt={`Cover image for "${title}"`}
              class="h-auto max-h-[28rem] w-full object-cover"
              loading="eager"
              itemprop="image"
            />
          </figure>
        )}
      </header>

      <!-- ═══════════════ PROSE DIVIDER ═══════════════════════════ -->
      <div class="mb-12 flex items-center gap-4" aria-hidden="true">
        <span class="h-px flex-1 bg-base-300/70"></span>
        <span class="inline-flex h-1.5 w-1.5 rounded-full bg-primary/40"></span>
        <span class="h-px flex-1 bg-base-300/70"></span>
      </div>

      <!-- ═══════════════ PROSE BODY ══════════════════════════════ -->
      <!--
        max-w-[46rem] gives ~70ch line length for comfortable reading.
        prose-blug sets max-w-none so this wrapper controls the width.
      -->
      <div class="mx-auto max-w-[46rem]">
        <section
          class="
            prose prose-blug prose-lg max-w-none

            prose-headings:font-extrabold
            prose-headings:tracking-tight
            prose-headings:scroll-mt-24
            prose-headings:text-balance

            prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-2xl
            prose-h3:mt-8  prose-h3:mb-3 prose-h3:text-xl
            prose-h4:mt-6  prose-h4:mb-2 prose-h4:text-lg

            prose-p:leading-[1.85] prose-p:text-base-content/75

            prose-a:text-primary prose-a:font-medium
            prose-a:no-underline prose-a:border-b prose-a:border-primary/25
            prose-a:transition-all prose-a:duration-150
            prose-a:hover:border-primary prose-a:hover:text-primary

            prose-strong:font-semibold prose-strong:text-base-content

            prose-code:rounded-md
            prose-code:border prose-code:border-base-300/60
            prose-code:bg-base-200
            prose-code:px-[0.35em] prose-code:py-[0.15em]
            prose-code:text-[0.875em]
            prose-code:font-medium
            prose-code:text-base-content/90
            prose-code:before:content-none prose-code:after:content-none

            prose-pre:rounded-2xl
            prose-pre:border prose-pre:border-base-300/50
            prose-pre:shadow-card
            prose-pre:text-sm

            prose-blockquote:not-italic
            prose-blockquote:border-l-[3px] prose-blockquote:border-primary/35
            prose-blockquote:bg-base-200/60
            prose-blockquote:rounded-r-xl
            prose-blockquote:py-3 prose-blockquote:px-5
            prose-blockquote:text-base-content/70

            prose-img:rounded-2xl
            prose-img:border prose-img:border-base-300/50
            prose-img:shadow-card

            prose-hr:border-base-300/60 prose-hr:my-10

            prose-table:text-sm
            prose-th:font-semibold
            prose-thead:border-b-base-300

            prose-li:marker:text-primary
          "
          aria-label="Article body"
          itemprop="articleBody"
        >
          <slot />
        </section>
      </div>

      <!-- ═══════════════ POST FOOTER ═════════════════════════════ -->
      <footer class="mx-auto mt-16 max-w-[46rem]">
        <!-- Decorative divider -->
        <div class="mb-8 flex items-center gap-4" aria-hidden="true">
          <span class="h-px flex-1 bg-base-300/70"></span>
          <span class="inline-flex h-1.5 w-1.5 rounded-full bg-base-300"></span>
          <span class="h-px flex-1 bg-base-300/70"></span>
        </div>

        <div class="flex flex-col items-start justify-between gap-5 sm:flex-row sm:items-center">
          <!-- Filed-under tags -->
          {tags.length > 0 && (
            <div class="space-y-2">
              <p class="text-2xs font-semibold uppercase tracking-[0.12em] text-base-content/35">
                Filed under
              </p>
              <TagList
                client:load
                tags={tags}
                variant="solid"
                ariaLabel="Post tags"
              />
            </div>
          )}

          <!-- Back button -->
          <a
            href="/"
            class="inline-flex shrink-0 items-center gap-2 rounded-xl border border-base-300/80 bg-base-100 px-4 py-2.5 text-sm font-medium text-base-content/60 shadow-card transition-all duration-150 hover:border-primary/30 hover:text-primary hover:shadow-card-md"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            Back to all posts
          </a>
        </div>
      </footer>

    </article>
  </div>
</BaseLayout>

<!--
  Reading progress bar — only wired on post pages.
  Updates #reading-progress width as the user scrolls.
-->
<script is:inline>
  (function () {
    var bar = document.getElementById('reading-progress');
    if (!bar) return;

    function update() {
      var body  = document.body;
      var html  = document.documentElement;
      var total = Math.max(body.scrollHeight, html.scrollHeight) - html.clientHeight;
      var pct   = total > 0 ? (html.scrollTop / total) * 100 : 0;
      bar.style.width = pct.toFixed(1) + '%';
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>
