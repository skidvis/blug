---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).filter((p) => !p.data.draft);

// Build tag → count map, sorted by count desc then alpha
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].sort((a, b) => {
  if (b[1] !== a[1]) return b[1] - a[1];
  return a[0].localeCompare(b[0]);
});

// Largest count for relative bar widths
const maxCount = tags[0]?.[1] ?? 1;
---
<BaseLayout title="Tags" description="Browse all topics covered across published posts.">
  <div class="mx-auto max-w-4xl space-y-10">

    <!-- Header -->
    <header class="space-y-3">
      <span class="eyebrow">Browse by topic</span>
      <h1 class="text-balance text-3xl font-extrabold tracking-tight text-base-content sm:text-4xl">
        All tags
      </h1>
      <p class="text-base text-base-content/55">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} across{' '}
        {tags.length} {tags.length === 1 ? 'topic' : 'topics'}.
      </p>
    </header>

    {tags.length === 0 ? (
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-base-content/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2H2v10l9.29 9.29a1 1 0 0 0 1.41 0l7.71-7.71a1 1 0 0 0 0-1.41z"/>
          <circle cx="7" cy="7" r="1"/>
        </svg>
        <p class="font-medium text-base-content/40">No tags yet.</p>
        <p class="text-sm text-base-content/30">Tags appear here once posts are published.</p>
      </div>
    ) : (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {tags.map(([tag, count]) => {
          const pct = Math.round((count / maxCount) * 100);
          return (
            <a
              href={`/tags/${encodeURIComponent(tag)}/`}
              class="group relative overflow-hidden rounded-2xl border border-base-300/80 bg-base-100 px-5 py-4 shadow-card transition-all duration-200 hover:border-primary/30 hover:shadow-card-md focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:outline-none"
            >
              <!-- Relative-popularity fill bar -->
              <div
                class="pointer-events-none absolute bottom-0 left-0 h-0.5 bg-primary/20 transition-all duration-300 group-hover:bg-primary/35"
                style={`width: ${pct}%`}
                aria-hidden="true"
              ></div>

              <div class="flex items-center justify-between gap-3">
                <div class="min-w-0 space-y-0.5">
                  <p class="truncate font-semibold text-base-content transition-colors duration-150 group-hover:text-primary">
                    <span class="select-none opacity-30" aria-hidden="true">#</span>{tag}
                  </p>
                  <p class="text-sm text-base-content/45">
                    {count} {count === 1 ? 'post' : 'posts'}
                  </p>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 shrink-0 text-base-content/25 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-primary"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
