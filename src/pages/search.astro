---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.vue';
---
<BaseLayout title="Search" description="Search all published blog posts by title, excerpt, or body text.">
  <div class="mx-auto max-w-3xl space-y-10">

    <!-- Header -->
    <header class="space-y-3">
      <span class="eyebrow">Full-text search</span>
      <h1 class="text-balance text-3xl font-extrabold tracking-tight text-base-content sm:text-4xl">
        Find a post
      </h1>
      <p class="text-base leading-relaxed text-base-content/55">
        Search across all post titles, excerpts, and body text.
        Results are powered by a{' '}
        <a
          href="https://pagefind.app"
          class="text-primary underline underline-offset-2 transition-colors hover:text-primary/80"
          target="_blank"
          rel="noopener noreferrer"
        >Pagefind</a>{' '}
        index generated at build time — zero server required.
      </p>
    </header>

    <!-- Keyboard shortcut hint strip -->
    <div class="flex items-center gap-2 text-xs text-base-content/35">
      <span>Tip: press</span>
      <span class="kbd-badge">↑</span>
      <span class="kbd-badge">↓</span>
      <span>to navigate results,</span>
      <span class="kbd-badge">Enter</span>
      <span>to open.</span>
    </div>

    <!-- Search widget -->
    <SearchBox client:load />

  </div>
</BaseLayout>
