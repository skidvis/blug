---
export const prerender = false;

import AdminPageLayout from '../../../layouts/AdminPageLayout.astro';
import AdminLayout from '../../../components/admin/AdminLayout.vue';
import PostForm from '../../../components/admin/PostForm.vue';
---
<AdminPageLayout title="New post">
<AdminLayout client:load={false} title="New post" currentPath={Astro.url.pathname}>
  <section class="mx-auto flex max-w-6xl flex-col gap-6">
    <div class="flex items-center justify-between gap-3">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Admin</p>
        <h1 class="text-3xl font-bold">New post</h1>
      </div>
      <a href="/admin/posts" class="btn btn-outline">Back to posts</a>
    </div>

    <div class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
      <PostForm client:load />
    </div>
  </section>
</AdminLayout>
</AdminPageLayout>
